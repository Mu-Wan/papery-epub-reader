{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "页间",
  "version": "1.1.3",
  "identifier": "com.papery.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "页间 · EPUB 阅读器",
        "width": 1180,
        "height": 820,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "fullscreen": false,
        "backgroundColor": "#f3f1ec"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
